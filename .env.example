# ─────────────────────────────────────────────────────────────────────────────
# Unstuck Internal Dashboard — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file, fill in the real values, and add them to Render.com under:
#   Dashboard → your service → Environment → Add Environment Variable
#
# DO NOT commit a filled-in copy of this file to Git.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase (Mail Merge Tool — Sender Profiles) ──────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Your project's API URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Public anon key (safe for server-side use; NOT the service_role key)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
